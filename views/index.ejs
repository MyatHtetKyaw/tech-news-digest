<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tech News Digest</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #06060e;
      --surface: rgba(255, 255, 255, 0.03);
      --surface-hover: rgba(255, 255, 255, 0.06);
      --border: rgba(255, 255, 255, 0.06);
      --border-glow: rgba(99, 102, 241, 0.3);
      --text: #f0f0f5;
      --muted: #6b7280;
      --accent: #818cf8;
      --accent-bright: #a5b4fc;
      --green: #34d399;
      --green-glow: rgba(52, 211, 153, 0.3);
      --orange: #fb923c;
      --pink: #f472b6;
      --cyan: #22d3ee;
      --violet: #a78bfa;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      min-height: 100vh;
      overflow-x: hidden;
      position: relative;
    }

    /* ── Animated gradient mesh background ── */
    .bg-mesh {
      position: fixed;
      inset: 0;
      z-index: -2;
      overflow: hidden;
    }
    .bg-mesh .orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.35;
      animation: float 20s ease-in-out infinite;
    }
    .bg-mesh .orb:nth-child(1) {
      width: 600px; height: 600px;
      background: radial-gradient(circle, #6366f1, transparent 70%);
      top: -10%; left: -10%;
      animation-duration: 25s;
    }
    .bg-mesh .orb:nth-child(2) {
      width: 500px; height: 500px;
      background: radial-gradient(circle, #ec4899, transparent 70%);
      top: 40%; right: -15%;
      animation-duration: 30s;
      animation-delay: -5s;
    }
    .bg-mesh .orb:nth-child(3) {
      width: 450px; height: 450px;
      background: radial-gradient(circle, #06b6d4, transparent 70%);
      bottom: -10%; left: 30%;
      animation-duration: 22s;
      animation-delay: -10s;
    }
    @keyframes float {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(30px, -40px) scale(1.05); }
      66% { transform: translate(-20px, 30px) scale(0.95); }
    }

    /* ── Noise texture overlay ── */
    .bg-noise {
      position: fixed;
      inset: 0;
      z-index: -1;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 256px 256px;
    }

    /* ── Custom scrollbar ── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }

    /* ── Layout ── */
    .container {
      max-width: 880px;
      margin: 0 auto;
      padding: 3rem 1.5rem 4rem;
    }

    /* ── Glass card mixin-style ── */
    .glass {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }

    /* ── Header ── */
    header {
      text-align: center;
      margin-bottom: 3rem;
      animation: fadeSlideDown 0.8s ease-out;
    }
    .logo-mark {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 56px; height: 56px;
      border-radius: 16px;
      background: linear-gradient(135deg, #6366f1, #ec4899);
      margin-bottom: 1rem;
      font-size: 1.6rem;
      box-shadow: 0 0 40px rgba(99, 102, 241, 0.3);
      animation: pulse-glow 3s ease-in-out infinite;
    }
    @keyframes pulse-glow {
      0%, 100% { box-shadow: 0 0 30px rgba(99, 102, 241, 0.25); }
      50% { box-shadow: 0 0 50px rgba(99, 102, 241, 0.45), 0 0 80px rgba(236, 72, 153, 0.15); }
    }
    header h1 {
      font-size: 2.4rem;
      font-weight: 900;
      letter-spacing: -0.03em;
      background: linear-gradient(135deg, #e0e7ff 0%, #a5b4fc 30%, #818cf8 50%, #c084fc 70%, #f0abfc 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    header .subtitle {
      color: var(--muted);
      font-size: 0.875rem;
      margin-top: 0.5rem;
      font-weight: 400;
      letter-spacing: 0.02em;
    }
    header .subtitle a {
      color: var(--accent-bright);
      text-decoration: none;
      border-bottom: 1px solid rgba(165, 180, 252, 0.3);
      transition: border-color 0.2s;
    }
    header .subtitle a:hover { border-color: var(--accent-bright); }
    .meta-pills {
      display: flex;
      justify-content: center;
      gap: 0.75rem;
      margin-top: 1rem;
      flex-wrap: wrap;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.3rem 0.75rem;
      border-radius: 100px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      font-size: 0.75rem;
      color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
      font-weight: 500;
    }
    .pill .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--green);
      box-shadow: 0 0 8px var(--green-glow);
      animation: blink 2s ease-in-out infinite;
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    /* ── Summary card ── */
    .summary-wrap {
      position: relative;
      margin-bottom: 2.5rem;
      animation: fadeSlideUp 0.8s ease-out 0.15s both;
    }
    .summary-wrap::before {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: 17px;
      background: linear-gradient(135deg, rgba(99,102,241,0.4), rgba(236,72,153,0.2), rgba(6,182,212,0.3));
      z-index: -1;
      opacity: 0.6;
    }
    .summary {
      padding: 1.5rem 1.75rem;
      font-size: 0.95rem;
      line-height: 1.8;
      position: relative;
    }
    .summary-header {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 0.75rem;
    }
    .summary-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px; height: 28px;
      border-radius: 8px;
      background: linear-gradient(135deg, #34d399, #06b6d4);
      font-size: 0.8rem;
    }
    .summary h2 {
      font-size: 0.8rem;
      color: var(--green);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 700;
    }
    .summary p {
      color: rgba(240, 240, 245, 0.8);
    }

    /* ── Category sections ── */
    .category {
      margin-bottom: 2.5rem;
      animation: fadeSlideUp 0.6s ease-out both;
    }
    .category:nth-child(1) { animation-delay: 0.3s; }
    .category:nth-child(2) { animation-delay: 0.4s; }
    .category:nth-child(3) { animation-delay: 0.5s; }
    .category:nth-child(4) { animation-delay: 0.6s; }
    .category:nth-child(5) { animation-delay: 0.7s; }
    .category-header {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 1rem;
      padding-bottom: 0.6rem;
      border-bottom: 1px solid var(--border);
    }
    .category-icon {
      font-size: 1.1rem;
      width: 32px; height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
    }
    .category h3 {
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--text);
    }
    .category-count {
      margin-left: auto;
      font-size: 0.7rem;
      color: var(--muted);
      font-family: 'JetBrains Mono', monospace;
      background: rgba(255,255,255,0.04);
      padding: 0.15rem 0.55rem;
      border-radius: 100px;
      border: 1px solid var(--border);
    }

    /* ── Story cards ── */
    .stories {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .story {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.85rem 1rem;
      border-radius: 12px;
      background: var(--surface);
      border: 1px solid transparent;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      position: relative;
      overflow: hidden;
    }
    .story::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 12px;
      background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(236,72,153,0.04));
      opacity: 0;
      transition: opacity 0.25s;
    }
    .story:hover {
      border-color: var(--border-glow);
      transform: translateX(4px);
      background: var(--surface-hover);
    }
    .story:hover::before { opacity: 1; }
    .story .rank {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--muted);
      min-width: 1.8rem;
      text-align: center;
      opacity: 0.6;
      position: relative;
      z-index: 1;
    }
    .story .info {
      flex: 1;
      min-width: 0;
      position: relative;
      z-index: 1;
    }
    .story .title {
      font-weight: 600;
      font-size: 0.9rem;
      text-decoration: none;
      color: var(--text);
      transition: color 0.2s;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .story:hover .title { color: var(--accent-bright); }
    .story .meta-line {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 0.2rem;
      font-family: 'JetBrains Mono', monospace;
      font-weight: 400;
    }
    .story .meta-line .author { color: var(--violet); }
    .story .meta-line .comments { color: var(--cyan); }
    .story .score {
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.25rem 0.65rem;
      border-radius: 100px;
      font-size: 0.75rem;
      font-weight: 600;
      font-family: 'JetBrains Mono', monospace;
      color: var(--green);
      background: rgba(52, 211, 153, 0.08);
      border: 1px solid rgba(52, 211, 153, 0.15);
      white-space: nowrap;
      flex-shrink: 0;
      transition: all 0.25s;
    }
    .story:hover .score {
      background: rgba(52, 211, 153, 0.15);
      box-shadow: 0 0 16px rgba(52, 211, 153, 0.15);
    }
    .story .score .arrow {
      font-size: 0.6rem;
    }

    /* ── Footer ── */
    footer {
      margin-top: 4rem;
      text-align: center;
      animation: fadeSlideUp 0.8s ease-out 0.8s both;
    }
    .footer-line {
      width: 60px;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border-glow), transparent);
      margin: 0 auto 1.5rem;
    }
    footer p {
      color: var(--muted);
      font-size: 0.75rem;
      font-family: 'JetBrains Mono', monospace;
    }
    footer a {
      color: var(--accent);
      text-decoration: none;
      transition: color 0.2s;
    }
    footer a:hover { color: var(--accent-bright); }
    .refresh-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1rem;
      padding: 0.65rem 1.5rem;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      color: white;
      border: none;
      border-radius: 100px;
      font-weight: 600;
      font-size: 0.85rem;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      letter-spacing: 0.01em;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 20px rgba(99, 102, 241, 0.3);
      position: relative;
      overflow: hidden;
    }
    .refresh-btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, #818cf8, #a78bfa);
      opacity: 0;
      transition: opacity 0.3s;
    }
    .refresh-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(99, 102, 241, 0.45);
    }
    .refresh-btn:hover::before { opacity: 1; }
    .refresh-btn:active { transform: translateY(0); }
    .refresh-btn span { position: relative; z-index: 1; }
    .refresh-btn .btn-icon {
      position: relative;
      z-index: 1;
      display: inline-block;
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .refresh-btn:hover .btn-icon { transform: rotate(180deg); }

    /* ── Entrance animations ── */
    @keyframes fadeSlideDown {
      from { opacity: 0; transform: translateY(-20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeSlideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      .container { padding: 2rem 1rem 3rem; }
      header h1 { font-size: 1.8rem; }
      .story { padding: 0.7rem 0.8rem; gap: 0.5rem; }
      .story .rank { min-width: 1.4rem; }
      .summary { padding: 1.2rem 1.25rem; }
    }
  </style>
</head>
<body>
  <div class="bg-mesh">
    <div class="orb"></div>
    <div class="orb"></div>
    <div class="orb"></div>
  </div>
  <div class="bg-noise"></div>

  <div class="container">
    <header>
      <div class="logo-mark">&#128240;</div>
      <h1>Tech News Digest</h1>
      <p class="subtitle">
        Top <%= digest.total %> stories from
        <a href="https://news.ycombinator.com">Hacker News</a>
      </p>
      <div class="meta-pills">
        <span class="pill"><span class="dot"></span> live</span>
        <span class="pill">&#128197; <%= new Date(digest.fetchedAt).toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' }) %></span>
        <span class="pill">&#128198; <%= new Date(digest.fetchedAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></span>
      </div>
    </header>

    <div class="summary-wrap">
      <div class="summary glass">
        <div class="summary-header">
          <span class="summary-icon">&#128161;</span>
          <h2>Today's Briefing</h2>
        </div>
        <p><%= summary %></p>
      </div>
    </div>

    <%
      var categoryIcons = {
        'AI & Machine Learning': '&#129302;',
        'AI': '&#129302;',
        'Programming': '&#128187;',
        'Web Development': '&#127760;',
        'Security': '&#128274;',
        'Startups & Business': '&#128640;',
        'Startups': '&#128640;',
        'Hardware & Science': '&#9889;',
        'Hardware': '&#9889;',
        'Science': '&#128300;',
        'Open Source': '&#128736;',
        'Culture & Other': '&#127912;',
        'Culture': '&#127912;',
        'Other': '&#11088;'
      };
      function getIcon(name) {
        if (categoryIcons[name]) return categoryIcons[name];
        for (var key in categoryIcons) {
          if (name.toLowerCase().indexOf(key.toLowerCase()) !== -1) return categoryIcons[key];
        }
        return '&#128196;';
      }
    %>

    <% digest.groups.forEach(function(group, gi) { %>
      <div class="category" style="animation-delay: <%= (0.3 + gi * 0.1) %>s;">
        <div class="category-header">
          <span class="category-icon"><%- getIcon(group.name) %></span>
          <h3><%= group.name %></h3>
          <span class="category-count"><%= group.stories.length %></span>
        </div>
        <div class="stories">
          <% group.stories.forEach(function(story, i) { %>
            <a class="story" href="<%= story.url %>" target="_blank" rel="noopener" style="text-decoration: none; color: inherit;">
              <span class="rank"><%= String(i + 1).padStart(2, '0') %></span>
              <div class="info">
                <div class="title"><%= story.title %></div>
                <div class="meta-line">
                  <span class="author">@<%= story.author %></span> &middot; <span class="comments"><%= story.comments %> comments</span>
                </div>
              </div>
              <span class="score"><span class="arrow">&#9650;</span> <%= story.score %></span>
            </a>
          <% }); %>
        </div>
      </div>
    <% }); %>

    <footer>
      <div class="footer-line"></div>
      <p>Data from the <a href="https://github.com/HackerNews/API">HackerNews API</a></p>
      <form action="/" method="GET">
        <button class="refresh-btn" type="submit">
          <span class="btn-icon">&#128260;</span>
          <span>Refresh</span>
        </button>
      </form>
    </footer>
  </div>
</body>
</html>
